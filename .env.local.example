# Chemin vers le fichier Excel — OPTIONNEL.
# Depuis l'app : Réglages → « Choisir un fichier existant » ou « Créer un nouveau fichier ».
# Le choix est persisté dans config.json (dossier de données utilisateur).
# Si tu préfères forcer un chemin via cette variable, elle est utilisée en fallback.
#   1. Local : ./data/Investissement.xlsx
#   2. Google Drive Desktop (voir README) :
#      ~/Library/CloudStorage/GoogleDrive-<ton-email>/My Drive/<dossier>/Investissement.xlsx
# EXCEL_PATH=./data/Investissement.xlsx

# Optionnel — l'API publique CoinGecko sans clef suffit pour un usage personnel (100 req/min).
COINGECKO_API_KEY=
